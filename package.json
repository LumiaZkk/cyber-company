{
  "name": "claw-sims-company",
  "private": true,
  "description": "Claw Company: the first playable company sim inside Claw Sims, built on OpenClaw",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "authority:dev": "tsx watch packages/authority-daemon/src/server.ts",
    "authority:start": "npm run authority:preflight && tsx packages/authority-daemon/src/server.ts",
    "authority:doctor": "tsx packages/authority-daemon/src/ops-cli.ts doctor",
    "authority:backup": "tsx packages/authority-daemon/src/ops-cli.ts backup",
    "authority:backups": "tsx packages/authority-daemon/src/ops-cli.ts backups",
    "authority:migrate": "tsx packages/authority-daemon/src/ops-cli.ts migrate",
    "authority:restore": "tsx packages/authority-daemon/src/ops-cli.ts restore",
    "authority:rehearse": "tsx packages/authority-daemon/src/ops-cli.ts rehearse",
    "authority:preflight": "tsx packages/authority-daemon/src/ops-cli.ts preflight",
    "authority:typecheck": "tsc -p packages/authority-daemon/tsconfig.json --noEmit",
    "build": "npm run authority:typecheck && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.18.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
